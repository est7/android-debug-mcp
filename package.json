{
  "name": "android-debug-mcp",
  "version": "0.5.3",
  "private": true,
  "type": "module",
  "bin": {
    "android-debug-mcp": "server/src/server.ts"
  },
  "scripts": {
    "dev": "bun run server/src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "pngjs": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "typescript": "^5.7.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
